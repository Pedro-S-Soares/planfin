{
  "expo": {
    "name": "Planfin",
    "slug": "planfin",
    "scheme": "planfin",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#6255EA"
    },
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#6255EA"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "favicon": "./assets/favicon.png",
      "name": "Planfin",
      "shortName": "Planfin",
      "description": "Planejamento financeiro diário",
      "lang": "pt-BR",
      "themeColor": "#6255EA",
      "backgroundColor": "#ffffff",
      "display": "standalone",
      "startUrl": "/"
    },
    "plugins": [
      "expo-secure-store",
      "@react-native-community/datetimepicker"
    ]
  }
}
